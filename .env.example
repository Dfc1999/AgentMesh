# AgentMesh local development environment.

# LLM provider credentials.
# Default local profile is Gemini. Do not commit real keys.
AGENTMESH_MODEL_PROFILE=gemini
GEMINI_API_KEY=replace-me
GOOGLE_API_KEY=

# Azure OpenAI is ready for the GPT profile. Your teammate only needs to fill these.
# AGENTMESH_MODEL_PROFILE=azure
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT_GPT_4_1_MINI=
AZURE_OPENAI_DEPLOYMENT_GPT_4_1=
AZURE_OPENAI_DEPLOYMENT_GPT_5=

# Legacy non-active OpenAI public API provider. Leave empty unless explicitly needed.
OPENAI_API_KEY=

# Local data infrastructure.
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://agentmesh:agentmesh@localhost:5432/agentmesh?schema=public

# Solana local/devnet connectivity.
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com
AGENT_KEYPAIR_PATH=./keys/devnet-agent.json

# Runtime.
NODE_ENV=development
LOG_LEVEL=debug

# EPIC-03 optimizer feature flags.
ENABLE_SEMANTIC_CACHE=true
ENABLE_INTENT_CLASSIFIER=true
ENABLE_SKILL_MATCHING=true
ENABLE_RAG=true
ENABLE_CONTEXT_PRUNING=true
ENABLE_PROMPT_CACHE=true
ENABLE_REAL_OPTIMIZER_LLM=false

# EPIC-03 optimizer thresholds and TTLs.
OPTIMIZER_SEMANTIC_CACHE_THRESHOLD=0.97
OPTIMIZER_SKILL_EXACT_THRESHOLD=0.98
OPTIMIZER_SKILL_PARTIAL_THRESHOLD=0.95
OPTIMIZER_RAG_TOP_K=5
OPTIMIZER_RAG_MIN_SCORE=0.70
OPTIMIZER_PRUNING_DUPLICATE_THRESHOLD=0.90
OPTIMIZER_PRUNING_MIN_RELEVANCE=0.30
OPTIMIZER_DEFAULT_CACHE_TTL_SECONDS=3600
OPTIMIZER_DEFI_CACHE_TTL_SECONDS=300
