# AgentMesh local development environment.

# LLM provider credentials.
ANTHROPIC_API_KEY=replace-me
OPENAI_API_KEY=replace-me
GOOGLE_API_KEY=replace-me

# Local data infrastructure.
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://agentmesh:agentmesh@localhost:5432/agentmesh?schema=public

# Solana local/devnet connectivity.
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com
AGENT_KEYPAIR_PATH=./keys/devnet-agent.json

# Runtime.
NODE_ENV=development
LOG_LEVEL=debug
