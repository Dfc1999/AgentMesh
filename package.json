{
  "name": "agentmesh",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.9.0",
  "description": "AgentMesh monorepo: decentralized multi-agent economy on Solana.",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "eval:optimizer": "tsx scripts/eval-optimizer.ts",
    "eval:router": "tsx scripts/eval-router.ts",
    "eval:judge": "tsx scripts/eval-judge.ts",
    "eval:orchestrator": "tsx scripts/eval-orchestrator.ts",
    "eval:workers": "tsx scripts/eval-workers.ts",
    "eval:x402": "tsx scripts/eval-x402.ts",
    "eval:sdk": "tsx scripts/eval-sdk.ts",
    "test": "turbo run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "prisma": "^6.1.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ],
    "*.py": [
      "black",
      "isort"
    ],
    "*.rs": [
      "rustfmt"
    ]
  }
}
